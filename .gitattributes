# LF in the repository; native line endings on checkout (CRLF on Windows with core.autocrlf=true).
* text=auto

# Definite binaries — never apply text normalization.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.woff binary
*.woff2 binary
*.zip binary

# CPS wire-verify fixtures must keep exact bytes (CRLF good samples vs LF bad samples).
cps-verify/fixtures/** -text
