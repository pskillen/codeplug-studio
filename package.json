{
  "name": "codeplug-studio",
  "private": true,
  "type": "module",
  "scripts": {
    "generate:abbreviations": "node scripts/generate-abbreviations.mjs",
    "predev": "npm run generate:abbreviations",
    "prebuild": "npm run generate:abbreviations",
    "pretest": "npm run generate:abbreviations",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:cps-verify": "vitest run --config cps-verify/vitest.config.ts",
    "test:e2e": "playwright test",
    "test:system": "vitest run src/test/system",
    "test:watch": "vitest",
    "verify:codeplug": "node --experimental-strip-types cps-verify/src/cli.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@mantine/core": "^9.4.1",
    "@mantine/hooks": "^9.4.1",
    "@tabler/icons-react": "^3.44.0",
    "@tanstack/react-virtual": "^3.14.6",
    "@uiw/react-json-view": "^2.0.0-alpha.43",
    "fflate": "^0.8.3",
    "js-yaml": "^5.2.0",
    "leaflet": "^1.9.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^7.6.2",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/js-yaml": "^4.0.9",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^22.15.21",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.5.2",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.16",
    "postcss-preset-mantine": "^1.18.0",
    "postcss-simple-vars": "^7.0.1",
    "prettier": "^3.8.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^6.3.5",
    "vitest": "^4.1.9"
  }
}
